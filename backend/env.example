# ===========================================
# FEMAF Backend - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores
# Comando: copy env.example .env (Windows) ou cp env.example .env (Linux/Mac)

# Obrigatório: Access Token do Mercado Pago
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
# Use token de teste para desenvolvimento e token de produção para deploy
MP_ACCESS_TOKEN=

# URLs do frontend (para redirecionamento após pagamento)
# Em produção: https://extensao.femaf.com.br
BASE_URL=https://extensao.femaf.com.br

# Porta do servidor (opcional, padrão: 3000)
PORT=3000

# Timeout para chamadas à API Mercado Pago em ms (opcional, padrão: 10000)
MP_REQUEST_TIMEOUT=10000

# ===========================================
# Webhook (notificações de pagamento)
# ===========================================
# URL base do backend em HTTPS (obrigatório para o MP notificar pagamentos)
# Deve ser a URL que chega ao Express (ex.: App Runner), NÃO só o site estático:
# API_BASE_URL=https://xxxx.us-east-1.awsapprunner.com
# Se o domínio público apontar para o mesmo backend, pode ser esse domínio.
API_BASE_URL=

# Chave secreta do webhook (Painel MP > Webhooks > Configurar notificações)
# Usada para validar assinatura das notificações
MP_WEBHOOK_SECRET=

# ===========================================
# Moodle (rotas /moodle/test-user e test-create-user; depois webhook)
# ===========================================
# URL base do Moodle (ex: https://ead.femaf.com.br)
MOODLE_BASE_URL=https://ead.femaf.com.br
# Token do Web Service (core_user_get_users, core_user_create_users, core_enrol_get_enrolled_users, enrol_manual_enrol_users)
MOODLE_TOKEN=
# Papel de estudante no Moodle (confirmado: 5)
MOODLE_ROLE_ID=5
# Se o enrol retornar "Message was not sent": configure SMTP no Moodle ou desative e-mail
# na matrícula manual (Administração do site > Plugins > Matrícula > Matrícula manual).
# Senha ao criar usuário no webhook/testes se não vier no body (opcional; padrão: Temp@Moodle123)
# MOODLE_TEST_PASSWORD=Temp@Moodle123
# Opcional: mude a cada deploy para confirmar no /health que a versão nova subiu (ex.: 20260319-1)
# APP_DEPLOY_TAG=
